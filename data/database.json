  "queries": {
    "OpenOrders": {
      "title": "OpenOrders",
      "tables": ["Customers", "Orders", "OrderItems", "Products"],
      "connections": [
        { "from": "Customers.CustomerID", "to": "Orders.CustomerID" },
        { "from": "Orders.OrderID", "to": "OrderItems.OrderID" },
        { "from": "Products.ProductID", "to": "OrderItems.ProductID" }
      ],
      "fields": [
        { "field": "Company", "table": "Customers", "sort": "", "show": true, "criteria": "" },
        { "field": "OrderDate", "table": "Orders", "sort": "Descending", "show": true, "criteria": ">= Date()-30" },
        { "field": "ProductName", "table": "Products", "sort": "", "show": true, "criteria": "" },
        { "field": "Quantity", "table": "OrderItems", "sort": "", "show": true, "criteria": "> 0" },
        { "field": "Status", "table": "Orders", "sort": "", "show": true, "criteria": "\"Open\"" }
      ],
      "sql": "SELECT Customers.Company, Orders.OrderDate, Products.ProductName, OrderItems.Quantity, Orders.Status FROM Products INNER JOIN (Customers INNER JOIN (Orders INNER JOIN OrderItems ON Orders.OrderID = OrderItems.OrderID) ON Customers.CustomerID = Orders.CustomerID) ON Products.ProductID = OrderItems.ProductID WHERE Orders.OrderDate >= Date()-30 AND OrderItems.Quantity > 0 AND Orders.Status = \"Open\";"
    },
    "SalesByRegion": {
      "title": "SalesByRegion",
      "tables": ["Regions", "Customers", "Orders", "SalesTargets"],
      "connections": [
        { "from": "Regions.RegionID", "to": "Customers.RegionID" },
        { "from": "Customers.CustomerID", "to": "Orders.CustomerID" },
        { "from": "Regions.RegionID", "to": "SalesTargets.RegionID" }
      ],
      "fields": [
        { "field": "RegionName", "table": "Regions", "sort": "Ascending", "show": true, "criteria": "" },
        { "field": "Manager", "table": "Regions", "sort": "", "show": true, "criteria": "" },
        { "field": "Total", "table": "Orders", "sort": "", "show": true, "criteria": "Sum" },
        { "field": "TargetAmount", "table": "SalesTargets", "sort": "", "show": true, "criteria": "Q2" }
      ],
      "sql": "SELECT Regions.RegionName, Regions.Manager, Sum(Orders.Total) AS SalesTotal, SalesTargets.TargetAmount FROM (Regions INNER JOIN Customers ON Regions.RegionID = Customers.RegionID) INNER JOIN Orders ON Customers.CustomerID = Orders.CustomerID INNER JOIN SalesTargets ON Regions.RegionID = SalesTargets.RegionID GROUP BY Regions.RegionName, Regions.Manager, SalesTargets.TargetAmount;"
    }
  },
